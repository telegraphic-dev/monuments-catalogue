---
import Layout from '../layouts/Layout.astro';
import { getMonumentsSorted } from '../lib/content';

const monuments = await getMonumentsSorted();
---

<Layout title="Monuments Catalogue">
  <h1>Monuments Catalogue</h1>
  <p>Canonical routes are now based on imported monument entries and districts.</p>
  <ul>
    <li><a href="/monuments/">Browse monuments</a></li>
    <li><a href="/districts/">Browse districts</a></li>
  </ul>
  <p>Total monuments: {monuments.length}</p>
</Layout>
