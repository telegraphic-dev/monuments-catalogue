---
import Layout from '../../layouts/Layout.astro';
import { getCanonicalMonumentPath, getMonumentsSorted } from '../../lib/content';

const monuments = await getMonumentsSorted();
---

<Layout title="Monuments Catalogue | Monuments">
  <h1>Monuments</h1>
  <p>{monuments.length} imported monument entries.</p>
  <ul>
    {
      monuments.slice(0, 250).map((entry) => (
        <li>
          <a href={getCanonicalMonumentPath(entry)}>{entry.data.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
